        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="In this task you will see some words on the screen. The words will be written in red, green, or blue ink.&amp;#10;&amp;#10;Your job is to report the colour of the ink using the R, G, or B buttons on your keyboard.&amp;#10;&amp;#10;Press space to start!" valType="str" updates="constant" name="text"/>

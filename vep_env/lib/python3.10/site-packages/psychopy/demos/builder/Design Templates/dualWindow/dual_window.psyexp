      <CodeComponent name="experimenter_task_prog" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="# In the experimenter window we want to show a progress bar so we set that up here&amp;#10;task_prog = visual.Progress(&amp;#10;        win2, name='task_prog',&amp;#10;        progress=0.0,&amp;#10;        pos=(-0.2, 0), size=(0.5, 0.05), anchor='center-left', units='height',&amp;#10;        barColor=[-0.2549, 0.2392, 0.2549], backColor=None, borderColor='white', colorSpace='rgb',&amp;#10;        lineWidth=4.0, opacity=1.0, ori=0.0,&amp;#10;        depth=0&amp;#10;    )&amp;#10;&amp;#10;# Show some text with the progress bar&amp;#10;task_prog_text = visual.TextStim(win=win2, name='task_prog_text',&amp;#10;    text='Task progress:',&amp;#10;    font='Arial',&amp;#10;    pos=(-0.38, 0), height=0.03, wrapWidth=None, ori=0.0, &amp;#10;    color='white', colorSpace='rgb', opacity=None, &amp;#10;    languageStyle='LTR',&amp;#10;    depth=0.0);&amp;#10;&amp;#10;# Setup some text to show participant's accuracy&amp;#10;accuracy_text = visual.TextStim(win=win2, name='accuracy_text',&amp;#10;    text='placeholder',&amp;#10;    font='Arial',&amp;#10;    pos=(0, -0.2), height=0.03, wrapWidth=None, ori=0.0, &amp;#10;    color='white', colorSpace='rgb', opacity=None, &amp;#10;    languageStyle='LTR',&amp;#10;    depth=0.0);&amp;#10;&amp;#10;# Initialise a counter to track the accuracy&amp;#10;task_acc = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="task_prog = new visual.Progress(win2, {&quot;name&quot;: &quot;task_prog&quot;, &quot;progress&quot;: 0.0, &quot;pos&quot;: [(- 0.5), (- 0.4)], &quot;size&quot;: [1, 0.05], &quot;anchor&quot;: &quot;center left&quot;, &quot;units&quot;: &quot;height&quot;, &quot;barColor&quot;: [(- 0.2549), 0.2392, 0.2549], &quot;backColor&quot;: null, &quot;borderColor&quot;: &quot;white&quot;, &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 4.0, &quot;opacity&quot;: 1.0, &quot;ori&quot;: 0.0, &quot;depth&quot;: 0});&amp;#10;this_prop_complete = 0;&amp;#10;trials_complete = 0;&amp;#10;task_prog_text = new visual.TextBox2(win2, {&quot;text&quot;: &quot;Task progress&quot;, &quot;placeholder&quot;: &quot;Type here...&quot;, &quot;font&quot;: &quot;Arial&quot;, &quot;pos&quot;: [0, (- 0.3)], &quot;letterHeight&quot;: 0.03, &quot;size&quot;: [1, 0.01], &quot;borderWidth&quot;: 2.0, &quot;color&quot;: &quot;white&quot;, &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;bold&quot;: false, &quot;italic&quot;: false, &quot;lineSpacing&quot;: 1.0, &quot;speechPoint&quot;: null, &quot;padding&quot;: 0.0, &quot;alignment&quot;: &quot;center-left&quot;, &quot;anchor&quot;: &quot;center&quot;, &quot;overflow&quot;: &quot;visible&quot;, &quot;fillColor&quot;: null, &quot;borderColor&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;languageStyle&quot;: &quot;LTR&quot;, &quot;editable&quot;: false, &quot;name&quot;: &quot;task_prog_text&quot;, &quot;depth&quot;: (- 3), &quot;autoLog&quot;: true});&amp;#10;accuracy_text = new visual.TextBox2(win2, {&quot;text&quot;: &quot;Correct in last 10&quot;, &quot;placeholder&quot;: &quot;Type here...&quot;, &quot;font&quot;: &quot;Arial&quot;, &quot;pos&quot;: [0, (- 0.35)], &quot;letterHeight&quot;: 0.03, &quot;size&quot;: [1, 0.01], &quot;borderWidth&quot;: 2.0, &quot;color&quot;: &quot;white&quot;, &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;bold&quot;: false, &quot;italic&quot;: false, &quot;lineSpacing&quot;: 1.0, &quot;speechPoint&quot;: null, &quot;padding&quot;: 0.0, &quot;alignment&quot;: &quot;center-left&quot;, &quot;anchor&quot;: &quot;center&quot;, &quot;overflow&quot;: &quot;visible&quot;, &quot;fillColor&quot;: null, &quot;borderColor&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;languageStyle&quot;: &quot;LTR&quot;, &quot;editable&quot;: false, &quot;name&quot;: &quot;task_prog_text&quot;, &quot;depth&quot;: (- 3), &quot;autoLog&quot;: true});&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="trials_to_complete = currentLoop.totalN;&amp;#10;task_prog.setProgress(this_prop_complete);&amp;#10;task_prog.setAutoDraw(true);&amp;#10;task_prog_text.setAutoDraw(true);&amp;#10;accuracy_text.setText((((((&quot;Trials Complete: &quot; + trials_complete.toString()) + &quot;| Correct overall:&quot;) + overall_corr_count.toString()) + &quot;| Correct in last 10: &quot;) + last_10_corr_count.toString()));&amp;#10;accuracy_text.setAutoDraw(true);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Calculate how far the participant is through the trials (we add one to the current trial number&amp;#10;# to account for Python 0-indexing)&amp;#10;this_prop_complete = (trials.thisN+1)/trials.nTotal&amp;#10;&amp;#10;# Update the progress bar&amp;#10;task_prog.setProgress(this_prop_complete)&amp;#10;&amp;#10;# Update the accuracy text with current accuracy score&amp;#10;accuracy_text.setText('Task accuracy: ' + str(task_acc) + '/' + str(trials.thisN))&amp;#10;&amp;#10;# Draw the progress bar and text&amp;#10;task_prog.setAutoDraw(True)&amp;#10;task_prog_text.setAutoDraw(True)&amp;#10;accuracy_text.setAutoDraw(True)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="# Flip the experimenter's window&amp;#10;win2.flip()" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="this_prop_complete = (trials_complete / trials_to_complete);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="# Update the accuracy score&amp;#10;task_acc += key_resp.corr" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="experimenter_task_prog" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
  </Routines>
  <Flow>
    <Routine name="show_screens"/>
    <Routine name="instructions"/>
    <LoopInitiator loopType="TrialHandler" name="trials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'word_stim': 'RED', 'ink_col': 'red', 'corr_ans': 'r', 'trial_type': 'congruent'}, {'word_stim': 'RED', 'ink_col': 'green', 'corr_ans': 'g', 'trial_type': 'incongruent'}, {'word_stim': 'RED', 'ink_col': 'blue', 'corr_ans': 'b', 'trial_type': 'incongruent'}, {'word_stim': 'GREEN', 'ink_col': 'red', 'corr_ans': 'r', 'trial_type': 'incongruent'}, {'word_stim': 'GREEN', 'ink_col': 'green', 'corr_ans': 'g', 'trial_type': 'congruent'}, {'word_stim': 'GREEN', 'ink_col': 'blue', 'corr_ans': 'b', 'trial_type': 'incongruent'}, {'word_stim': 'BLUE', 'ink_col': 'red', 'corr_ans': 'r', 'trial_type': 'incongruent'}, {'word_stim': 'BLUE', 'ink_col': 'green', 'corr_ans': 'g', 'trial_type': 'incongruent'}, {'word_stim': 'BLUE', 'ink_col': 'blue', 'corr_ans': 'b', 'trial_type': 'congruent'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="conditions.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="trials" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="trial"/>
    <LoopTerminator name="trials"/>
    <Routine name="thanks"/>
  </Flow>
</PsychoPy2experiment>
